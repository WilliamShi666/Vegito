# Copy this file to .env for local shells that load dotenv files.
# Do not commit real provider credentials.

# Recommended for the bundled DeepSeek profiles:
DEEPSEEK_API_KEY=

# Compatibility options for Anthropic-compatible gateways:
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# OpenAI-compatible profiles:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
